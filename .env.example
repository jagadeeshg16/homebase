# Server
PORT=8080
INTERNAL_TOKEN=replace-with-random-secret
SESSION_SECRET=replace-with-random-secret

# DNS
DNS_PROVIDER=godaddy
ROOT_DOMAIN=yourdomain.in

# GoDaddy (if DNS_PROVIDER=godaddy)
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Cloudflare (if DNS_PROVIDER=cloudflare)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# DB (optional, defaults to ~/server/data/server.db)
# DB_PATH=/home/user/server/data/server.db
